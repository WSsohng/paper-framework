# Copy to .env.local and fill in values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# 전역 비밀번호 로그인 (middleware)
# 프로덕션: 반드시 설정. 로컬에서 비활성화하려면 비우거나 주석 처리.
SITE_PASSWORD=
# JWT 서명용 (16자 이상 권장). 프로덕션에서는 openssl rand -hex 32 등으로 생성.
AUTH_SECRET=
